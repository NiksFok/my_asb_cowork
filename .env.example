# === ОБЯЗАТЕЛЬНЫЕ ТОКЕНЫ ===

# Telegram Bot Token (от @BotFather)
TELEGRAM_BOT_TOKEN=

# Deepgram API Key (от console.deepgram.com, бесплатный кредит $200)
DEEPGRAM_API_KEY=

# === ОПЦИОНАЛЬНЫЕ ТОКЕНЫ ===

# Todoist API Token (todoist.com → Settings → Integrations → Developer)
TODOIST_API_KEY=

# YouTube Data API v3 Key (console.cloud.google.com)
YOUTUBE_API_KEY=

# Anthropic API Key (console.anthropic.com) — нужен только если Claude Code не авторизован
ANTHROPIC_API_KEY=

# Firecrawl API Key (firecrawl.dev) — для скрапинга веб-страниц
FIRECRAWL_API_KEY=

# Oura Ring Access Token (cloud.ouraring.com)
OURA_ACCESS_TOKEN=

# Supabase (app.supabase.com → Project Settings → API)
# URL вида: https://xxxxxxxxxxxx.supabase.co
SUPABASE_URL=
# service_role key (не anon! нужны права на запись без RLS)
SUPABASE_KEY=

# === НАСТРОЙКИ ===

# Путь к Obsidian vault (не менять)
VAULT_PATH=./vault

# Telegram ID пользователя (бот отвечает только вам)
# Узнать свой ID: @userinfobot в Telegram
ALLOWED_USER_IDS=[123456789]

# Включить ночную авто-имплементацию улучшений (true/false)
NIGHT_IMPLEMENT_ENABLED=false

# Включить модуль здоровья Oura Ring (true/false)
# Требует OURA_ACCESS_TOKEN. По умолчанию выключен.
HEALTH_ENABLED=false

# Локация по умолчанию (обновляется командой /location)
LOCATION_CITY=Москва
LOCATION_LAT=55.75
LOCATION_LON=37.62
LOCATION_TZ=Europe/Moscow

# Supabase — food logging database (app.supabase.com -> Settings -> API)
SUPABASE_URL=
SUPABASE_KEY=

# Nutrition profile — fill in your personal parameters
# Height and weight for KBZHU target calculation
NUTRITION_HEIGHT_CM=175
NUTRITION_WEIGHT_KG=80.0
NUTRITION_AGE=30
NUTRITION_GENDER=мужчина
NUTRITION_ACTIVITY=умеренная активность
NUTRITION_GOAL=поддерживать вес
NUTRITION_NOTES=
# Daily KBZHU targets (kcal / protein g / fat g / carbs g)
NUTRITION_DAILY_KCAL=2000
NUTRITION_DAILY_PROTEIN=150
NUTRITION_DAILY_FAT=55
NUTRITION_DAILY_CARBS=220
